{
  "entities": {
    "Donation": {
      "title": "Donation",
      "description": "A donation record from a user",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name of the donor" },
        "email": { "type": "string", "format": "email", "description": "Email of the donor" },
        "amount": { "type": "number", "description": "Donation amount in INR" },
        "message": { "type": "string", "description": "Message accompanying the donation" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the donation was made" },
        "razorpayOrderId": { "type": "string", "description": "The Razorpay Order ID" },
        "razorpayPaymentId": { "type": "string", "description": "The Razorpay Payment ID" },
        "verified": { "type": "boolean", "description": "Whether the payment has been verified server-side" },
        "pinned": { "type": "boolean", "description": "Whether this donation is pinned on screen" }
      },
      "required": ["name", "amount", "message", "timestamp", "verified"]
    },
    "GlobalConfig": {
      "title": "Global Configuration",
      "description": "Global settings for the donation platform",
      "type": "object",
      "properties": {
        "muted": { "type": "boolean", "description": "Whether TTS is muted globally" },
        "blockedWords": { "type": "array", "items": { "type": "string" }, "description": "List of words to filter" },
        "goal": { "type": "number", "description": "Current donation goal in INR" }
      }
    }
  },
  "firestore": {
    "donations": {
      "schema": "Donation",
      "description": "Collection of all donations"
    },
    "config": {
      "schema": "GlobalConfig",
      "description": "Global configuration settings"
    }
  }
}
